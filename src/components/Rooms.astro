---
// Rooms & Community Section - RStay Co-Living
const rooms = [
  {
    name: "Super Haven",
    desc: "Kamar paling luas dengan balkon pribadi. Cocok buat yang mau fokus total tanpa gangguan.",
    tag: "Work-Focus",
    img: "https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "Minimal Haven",
    desc: "Definisi 'Value, Not Stuff'. Ruangan efisien, meja kerja ergonomis, dan vibe ultra-minimalis.",
    tag: "Minimalist",
    img: "https://images.unsplash.com/photo-1598928506311-c55ded91a20c?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "The Flock Room",
    desc: "Kamar dengan akses paling dekat ke common area. Pas buat yang mau networking bareng creator lain.",
    tag: "Community",
    img: "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&q=80&w=800"
  }
];
---

<section id="rooms" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="mb-16 text-center md:text-left md:flex justify-between items-end">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 tracking-tighter">
          CHOOSE YOUR <span class="text-[#0047AB]">VIBE.</span>
        </h2>
        <p class="text-slate-500 text-lg">
          24 kamar yang dirancang khusus untuk kenyamanan jangka panjang. Semua satu harga, semua satu standar.
        </p>
      </div>
      <div class="hidden md:block">
        <span class="text-[#0047AB] font-black text-6xl opacity-10">450K</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {rooms.map((room) => (
        <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-100">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img 
              src={room.img} 
              alt={room.name} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            />
            <div class="absolute top-4 left-4">
              <span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest text-[#0047AB]">
                {room.tag}
              </span>
            </div>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-bold text-slate-900 mb-3">{room.name}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-6">
              {room.desc}
            </p>
            <div class="flex items-center justify-between pt-6 border-t border-slate-50">
              <span class="text-xl font-black text-[#0047AB]">450k<span class="text-xs text-slate-400 font-normal">/nett</span></span>
              <a href="#booking" class="text-xs font-bold uppercase tracking-widest border-b-2 border-[#0047AB] pb-1 hover:text-[#0047AB] transition-colors">
                Book Room
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 bg-[#0047AB] rounded-[3rem] p-10 md:p-16 text-white flex flex-col md:flex-row items-center gap-10">
      <div class="flex-1">
        <h3 class="text-3xl font-black mb-4">JOIN THE FLOCK</h3>
        <p class="text-blue-100 leading-relaxed">
          Bukan cuma sekadar tempat tidur. Di RStay, lu otomatis jadi bagian dari komunitas "The Flock". Ruang diskusi, networking, dan teman sharing buat project digital lu ada di sini.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-blue-500/30 p-4 rounded-2xl backdrop-blur-sm">
          <span class="block text-2xl mb-1">🚀</span>
          <span class="text-[10px] font-bold uppercase">Fast WiFi</span>
        </div>
        <div class="bg-blue-500/30 p-4 rounded-2xl backdrop-blur-sm">
          <span class="block text-2xl mb-1">☕</span>
          <span class="text-[10px] font-bold uppercase">Free Coffee</span>
        </div>
      </div>
    </div>

  </div>
</section>