---
// Footer Component - RStay Co-Living (Premium Version)
---

<footer class="bg-slate-900 text-slate-400 py-20 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start mb-20">
      
      <div class="lg:col-span-5">
        <img 
          src="../../public/logo.png" 
          alt="RStay Logo" 
          class="h-40 md:h-20 w-auto brightness-0 invert opacity-90 mb-8" 
        />
        <p class="text-lg text-slate-500 max-w-sm leading-relaxed italic">
          High-end co-living for the modern hustlers. <br/>
          Focus on your work, we handle the rest.
        </p>
      </div>

      <div class="hidden lg:block lg:col-span-1"></div>

      <div class="lg:col-span-3">
        <h4 class="text-white font-black uppercase tracking-[0.2em] text-xs mb-8">Navigation</h4>
        <ul class="space-y-4 font-bold uppercase text-sm tracking-widest">
          <li><a href="#rooms" class="hover:text-blue-400 transition-colors">The Haven</a></li>
          <li><a href="#community" class="hover:text-blue-400 transition-colors">The Flock</a></li>
          <li><a href="#booking" class="text-blue-500">Book A Spot</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-white font-black uppercase tracking-[0.2em] text-xs mb-8">Base</h4>
        <p class="text-sm font-medium leading-loose">
          Kampial, Nusa Dua <br/>
          Kec. Kuta Selatan, Kab. Badung <br/>
          Bali 80361, Indonesia
        </p>
        <div class="mt-6">
          <a href="https://wa.me/62812xxxxxx" class="text-blue-400 font-bold hover:underline">WhatsApp Support →</a>
        </div>
      </div>

    </div>

    <div class="pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-4">
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-600">RStay Co-Living</span>
        <div class="h-1 w-1 bg-slate-700 rounded-full"></div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">&copy; 2026</p>
      </div>
      
      <div class="flex items-center gap-2 group">
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-600">Developed by</span>
        <span class="text-white font-black tracking-tighter text-sm group-hover:text-blue-500 transition-colors">SORELABS</span>
      </div>
    </div>

  </div>
</footer>