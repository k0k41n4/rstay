---
// Hero Section - RStay Co-Living
---

<section
    class="relative min-h-[80vh] flex items-center overflow-hidden bg-white"
>
    <div
        class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center py-12 md:py-20"
    >
        <div class="z-10 order-2 lg:order-1">
            <div
                class="inline-block px-3 py-1 rounded-full bg-blue-50 text-[#0047AB] text-[10px] font-black uppercase tracking-widest mb-6"
            >
                📍 Premium Co-Living Nusa Dua
            </div>
            <h1
                class="text-5xl md:text-7xl font-black text-slate-900 leading-[1.1] mb-6"
            >
                Focus. <br />
                Connect. <br />
                <span class="text-[#0047AB]">Retreat.</span>
            </h1>
            <p
                class="text-lg md:text-xl text-slate-500 mb-10 max-w-md leading-relaxed"
            >
                Upgrade your lifestyle with our minimalist sanctuary. Built for
                the modern hustler and digital nomads.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
                <a
                    href="#booking"
                    class="bg-[#0047AB] text-white px-10 py-5 rounded-xl font-bold text-center shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all active:scale-95"
                >
                    Book Your Space — 450k
                </a>
                <a
                    href="#rooms"
                    class="border-2 border-slate-200 text-slate-600 px-10 py-5 rounded-xl font-bold text-center hover:bg-slate-50 transition-all"
                >
                    Explore Rooms
                </a>
            </div>

            <div class="mt-12 flex items-center gap-4">
                <div class="flex -space-x-3">
                    <div
                        class="w-10 h-10 rounded-full border-2 border-white bg-slate-200"
                    >
                    </div>
                    <div
                        class="w-10 h-10 rounded-full border-2 border-white bg-slate-300"
                    >
                    </div>
                    <div
                        class="w-10 h-10 rounded-full border-2 border-white bg-[#0047AB] flex items-center justify-center text-[10px] font-bold text-white"
                    >
                        20+
                    </div>
                </div>
                <p
                    class="text-xs font-medium text-slate-400 uppercase tracking-wider"
                >
                    Joined the flock this month
                </p>
            </div>
        </div>

        <div class="relative order-1 lg:order-2">
            <div
                class="relative z-10 rounded-3xl overflow-hidden shadow-2xl border-8 border-white transform lg:rotate-2 hover:rotate-0 transition-transform duration-500"
            >
                <img
                    src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=1000"
                    alt="RStay Room"
                    class="w-full h-full object-cover aspect-[4/5] lg:aspect-square"
                />
            </div>
            <div
                class="absolute -bottom-6 -left-6 w-32 h-32 bg-blue-100 rounded-full -z-0"
            >
            </div>
            <div
                class="absolute -top-10 -right-10 w-64 h-64 bg-slate-50 rounded-full -z-0 blur-3xl"
            >
            </div>
        </div>
    </div>
</section>
