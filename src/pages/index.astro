---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Rooms from '../components/Rooms.astro';
import Booking from '../components/Booking.svelte'; // Ini Svelte Component
---

<MainLayout title="Minimalist Sanctuary for Digital Nomads">
  
  <Hero />

  <Rooms />

  <section id="booking" class="py-24 bg-white border-t border-slate-50">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <div>
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-6 tracking-tighter uppercase italic">
          Ready to <br/><span class="text-[#0047AB]">Check-In?</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="bg-blue-50 p-3 rounded-xl h-fit">✅</div>
            <div>
              <p class="font-bold text-slate-900 text-sm italic underline">INSTANT CONFIRMATION</p>
              <p class="text-xs text-slate-500">Gak pake nunggu admin WA bales. Bayar, dapet kode, langsung beres.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="bg-blue-50 p-3 rounded-xl h-fit">💳</div>
            <div>
              <p class="font-bold text-slate-900 text-sm italic underline">SECURE PAYMENT</p>
              <p class="text-xs text-slate-500">Support QRIS, Credit Card, & Bank Transfer via Midtrans.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 bg-blue-100 rounded-[2rem] -rotate-1 z-0 opacity-50"></div>
        <div class="relative z-10">
          <Booking client:load /> 
        </div>
      </div>

    </div>
  </section>

</MainLayout>